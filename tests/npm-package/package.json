{
  "name": "@devforgeai/npm-package-tests",
  "version": "1.0.0",
  "description": "Test suite for DevForgeAI NPM package structure (STORY-066)",
  "private": true,
  "scripts": {
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:red": "jest --verbose --no-coverage --testMatch='**/*.test.js'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "tar": "^7.5.2"
  }
}
