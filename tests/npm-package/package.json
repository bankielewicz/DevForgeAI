{
  "name": "@devforgeai/npm-package-tests",
  "version": "1.0.0",
  "description": "Test suite for DevForgeAI NPM package structure (STORY-066)",
  "private": true,
  "scripts": {
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:red": "jest --verbose --no-coverage --testMatch='**/*.test.js'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "tar": "^7.5.2"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "../..",
    "setupFiles": ["<rootDir>/tests/npm-package/jest.setup.js"],
    "coverageDirectory": "tests/npm-package/coverage",
    "collectCoverageFrom": [
      "bin/**/*.js",
      "lib/**/*.js",
      "!**/node_modules/**",
      "!**/tests/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "testMatch": [
      "**/tests/npm-package/**/*.test.js"
    ],
    "verbose": true
  }
}
