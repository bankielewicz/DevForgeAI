{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DevForgeAI Feedback Session Schema",
  "description": "Structured schema for retrospective feedback collection",
  "type": "object",
  "required": ["feedback_id", "timestamp", "story_id", "workflow_type", "success_status"],
  "properties": {
    "feedback_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this feedback session"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of feedback submission"
    },
    "story_id": {
      "type": "string",
      "pattern": "^STORY-[0-9]+$",
      "description": "Story ID associated with operation"
    },
    "epic_id": {
      "type": "string",
      "pattern": "^EPIC-[0-9]+$",
      "description": "Epic ID (optional, derived from story)"
    },
    "workflow_type": {
      "type": "string",
      "enum": ["dev", "qa", "orchestrate", "release", "ideate", "create-story", "create-epic", "create-sprint"],
      "description": "Type of workflow that triggered feedback"
    },
    "success_status": {
      "type": "string",
      "enum": ["success", "failed", "partial"],
      "description": "Outcome of the operation"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "question_text", "response_type"],
        "properties": {
          "question_id": {
            "type": "string",
            "description": "Unique identifier for the question"
          },
          "question_text": {
            "type": "string",
            "description": "Text of the question presented to user"
          },
          "response_type": {
            "type": "string",
            "enum": ["rating", "multiple_choice", "open_text"],
            "description": "Type of response expected"
          },
          "response": {
            "oneOf": [
              {"type": "string"},
              {"type": "integer"},
              {"type": "null"}
            ],
            "description": "User's response to the question"
          },
          "skip": {
            "type": "boolean",
            "default": false,
            "description": "Whether user skipped this question"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "duration_seconds": {
          "type": "integer",
          "description": "Time spent on feedback session"
        },
        "total_questions": {
          "type": "integer",
          "description": "Total number of questions offered"
        },
        "answered": {
          "type": "integer",
          "description": "Number of questions answered"
        },
        "skipped": {
          "type": "integer",
          "description": "Number of questions skipped"
        }
      }
    }
  }
}
