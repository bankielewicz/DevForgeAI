{
  "permissions": {
    "allow": [
      "Skill(devforgeai-development)",
      "Bash(devforgeai-validate:*)",
      "Bash(chmod:*)",
      "Bash(~/.local/bin/devforgeai-validate:*)",
      "Bash(pip show:*)",
      "Bash(while read f)",
      "Bash(do:*)",
      "Bash(if [[ \"$f\" == *.md ]])",
      "Bash(then echo \"md\")",
      "Bash(elif [[ \"$f\" == *.json ]])",
      "Bash(then echo \"json\")",
      "Bash(elif [[ \"$f\" == *.lock ]])",
      "Bash(then echo \"lock\")",
      "Bash(elif [[ \"$f\" == *.ps1 ]])",
      "Bash(then echo \"ps1\")",
      "Bash(elif [[ \"$f\" == *.sh ]])",
      "Bash(then echo \"sh\")",
      "Bash(elif [[ \"$f\" == *SKILL* ]])",
      "Bash(then echo \"skill\")",
      "Bash(else echo \"other\")",
      "Bash(fi)",
      "Bash(done)",
      "Bash(bash:*)",
      "Bash(git show:*)",
      "Bash(echo:*)",
      "Bash(for test in devforgeai/tests/STORY-197/test-ac*.sh)",
      "Bash(if [ $? -eq 0 ])",
      "Bash(then)",
      "Bash(else)",
      "Bash(python3:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(./devforgeai/tests/STORY-199/run-all-tests.sh:*)",
      "Bash(/usr/bin/python3 -m pytest:*)",
      "Bash(for f in test-ac*.sh)",
      "Bash(do echo \"=== $f ===\")"
    ]
  }
}
